# Copy to .env and fill in
DATABASE_URL=postgresql://brandflow:brandflow@localhost:5433/brandflow
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me
# Access-token lifetime (default 15m; longer is convenient in dev)
JWT_EXPIRY=12h
# Leave empty to run AI features in offline sample mode
ANTHROPIC_API_KEY=
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=brandflow
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
PORT=3001
