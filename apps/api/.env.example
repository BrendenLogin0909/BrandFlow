# Copy to .env and fill in
DATABASE_URL=postgresql://brandflow:brandflow@localhost:5433/brandflow
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me
# Access-token lifetime (default 15m; longer is convenient in dev)
JWT_EXPIRY=12h
# ---------- AI provider ----------
# 'anthropic' | 'openai' | 'mock' — leave empty to auto-detect from the keys
# below (Anthropic preferred, then OpenAI, then offline sample mode).
AI_PROVIDER=
# Leave both empty to run AI features in offline sample mode
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Per-stage model overrides (apply to the active provider). Leave empty for
# the recommended defaults:
#   stage      anthropic default             openai default
#   ideation   claude-sonnet-5               gpt-5-mini
#   draft      claude-sonnet-5               gpt-5.1
#   final      claude-opus-4-8               gpt-5.1
#   review     claude-haiku-4-5-20251001     gpt-5-mini
# Model names change often — check docs.anthropic.com / platform.openai.com.
AI_MODEL_IDEATION=
AI_MODEL_DRAFT=
AI_MODEL_FINAL=
AI_MODEL_REVIEW=
# OpenAI reasoning effort for gpt-5-class models (minimal|low|medium|high).
# Copywriting doesn't need deep deliberation; default 'low' keeps drafts
# at ~20s instead of minutes.
AI_OPENAI_REASONING=
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=brandflow
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
PORT=3001
